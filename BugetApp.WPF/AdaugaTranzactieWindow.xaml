<Window x:Class="BugetApp.WPF.AdaugaTranzactieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adaugă Tranzacție" Height="480" Width="420"
        Background="#190019">
    <Border Background="#2B124C" Margin="15" CornerRadius="10" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Adăugare Tranzacție Nouă" FontSize="20" FontWeight="Bold" 
                       Foreground="#DFB6B2" HorizontalAlignment="Center" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20"/>

            <Label x:Name="lblSuma" Content="Sumă (RON):" Grid.Row="1" Grid.Column="0" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#FBE4D8"/>
            <TextBox x:Name="txtSuma" Grid.Row="1" Grid.Column="1" Margin="5" Padding="4" Background="#FBE4D8" Foreground="#190019" BorderThickness="0" VerticalAlignment="Center"/>

            <Label x:Name="lblDescriere" Content="Descriere:" Grid.Row="2" Grid.Column="0" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#FBE4D8"/>
            <TextBox x:Name="txtDescriere" Grid.Row="2" Grid.Column="1" Margin="5" Padding="4" Background="#FBE4D8" Foreground="#190019" BorderThickness="0" VerticalAlignment="Center"/>

            <Label x:Name="lblTip" Content="Tip tranzacție:" Grid.Row="3" Grid.Column="0" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#FBE4D8"/>
            <ComboBox x:Name="cmbTip" Grid.Row="3" Grid.Column="1" Margin="5" Padding="4" Background="#FBE4D8" Foreground="#190019" BorderThickness="0" VerticalAlignment="Center"/>

            <Label x:Name="lblData" Content="Data:" Grid.Row="4" Grid.Column="0" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#FBE4D8"/>
            <DatePicker x:Name="dpData" Grid.Row="4" Grid.Column="1" Margin="5" Padding="4" Background="#FBE4D8" Foreground="#190019" BorderThickness="0" VerticalAlignment="Center"/>
            
            <Label x:Name="lblOptiuni" Content="Opțiuni:" Grid.Row="5" Grid.Column="0" Margin="5" FontWeight="SemiBold" Foreground="#FBE4D8"/>
            <StackPanel Grid.Row="5" Grid.Column="1" Margin="5">
                <CheckBox x:Name="chkUrgent" Content="Urgent" Margin="0,0,0,5" Foreground="#FBE4D8"/>
                <CheckBox x:Name="chkPersonal" Content="Personal" Margin="0,0,0,5" Foreground="#FBE4D8"/>
                <CheckBox x:Name="chkRecurent" Content="Recurent" Margin="0,0,0,5" Foreground="#FBE4D8"/>
                <CheckBox x:Name="chkEsential" Content="Esențial" Foreground="#FBE4D8"/>
            </StackPanel>

            <Button x:Name="btnAdauga" Content="Adaugă Tranzacție" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" 
                    Margin="5,20,5,5" Height="40" Background="#854F6C" Foreground="#FBE4D8" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Click="btnAdauga_Click"/>

            <TextBlock x:Name="txtError" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Foreground="#DFB6B2" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" Margin="5,10,5,0"/>
        </Grid>
    </Border>
</Window>
