<Window x:Class="BugetApp.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PursePalette" Height="500" Width="750"
        Background="#F5E1E6"
        WindowStartupLocation="CenterScreen">

    <Grid>
        
        <Grid x:Name="HomeView" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
                <RowDefinition Height="60"/>   
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0" Margin="20,15,20,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Salut," FontSize="14" Foreground="#AA7F66"/>
                    <TextBlock Text="User!" FontSize="20" FontWeight="Bold" Foreground="#443025"/>
                </StackPanel>
                <Ellipse Grid.Column="1" Width="40" Height="40" Fill="#EC9C9D"/>
                <TextBlock Grid.Column="1" Text="👤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#443025"/>
            </Grid>

            
            <Grid Grid.Row="1" Margin="20,5,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                
                <Border Grid.Column="0" Margin="0,0,10,0" CornerRadius="15" Padding="20" Background="#443025">
                    <StackPanel>
                        <TextBlock Text="Sold curent" Foreground="#EC9C9D" FontSize="14"/>
                        <TextBlock x:Name="txtBalance" Text="0.00 RON" Foreground="#F5E1E6" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,10,0" BorderBrush="#AA7F66" BorderThickness="1">
                            <Grid>
                                <TextBox x:Name="txtSearch" Height="40" Padding="10,0" 
                                         VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0"
                                         Foreground="#443025" TextChanged="txtSearch_TextChanged"/>
                                <TextBlock Text="Caută tranzacții..." Foreground="#AA7F66" IsHitTestVisible="False" VerticalAlignment="Center" Margin="15,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        
                        <Button x:Name="btnDeschideAdaugare" Grid.Column="1" Content="+" Width="40" Height="40"
                                Background="#EC9C9D" Foreground="#443025" FontSize="20" FontWeight="Bold" BorderThickness="0"
                                Click="btnDeschideAdaugare_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    <TextBlock Text="Tranzacții recente" FontSize="16" FontWeight="Bold" Foreground="#443025" Margin="0,15,0,0"/>
                </StackPanel>
            </Grid>

            
            <ListBox x:Name="lstTranzactii" Grid.Row="2" Margin="20,0,20,10" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#F5E1E6" Margin="0,0,15,0">
                                    <TextBlock Text="{Binding Tip}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#7F5836"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Descriere}" FontWeight="Bold" FontSize="14" Foreground="#443025"/>
                                    <TextBlock Text="{Binding Data, StringFormat={}{0:dd MMM yyyy}}" FontSize="12" Foreground="#AA7F66" Margin="0,2,0,0"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Column="2" Text="{Binding Suma, StringFormat={}{0:N2} RON}" FontWeight="Bold" FontSize="14" Foreground="#7F5836" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            
            <Border Grid.Row="3" Background="White" CornerRadius="15,15,0,0" Margin="0" BorderBrush="#AA7F66" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Acasă" Background="Transparent" BorderThickness="0" Foreground="#443025" FontWeight="Bold" Click="btnNavHome_Click"/>
                    <Button Grid.Column="1" Content="Activitate" Background="Transparent" BorderThickness="0" Foreground="#AA7F66" FontWeight="SemiBold" Click="btnNavActivity_Click"/>
                    <Button Grid.Column="2" Content="Profil" Background="Transparent" BorderThickness="0" Foreground="#AA7F66" FontWeight="SemiBold"/>
                </Grid>
            </Border>
        </Grid>

        
        <Grid x:Name="ActivityView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
                <RowDefinition Height="60"/>   
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Activitate Săptămânală" FontSize="20" FontWeight="Bold" Foreground="#443025" Margin="20,15,20,10" HorizontalAlignment="Center"/>

            <Border Grid.Row="1" Background="White" CornerRadius="15" Margin="20,0,20,10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Ellipse Width="12" Height="12" Fill="#EC9C9D" Margin="0,0,5,0"/>
                        <TextBlock Text="Venituri" Margin="0,0,20,0" Foreground="#443025"/>
                        <Ellipse Width="12" Height="12" Fill="#7F5836" Margin="0,0,5,0"/>
                        <TextBlock Text="Cheltuieli" Foreground="#443025"/>
                    </StackPanel>

                    
                    <ItemsControl x:Name="icChart" Grid.Row="1" VerticalAlignment="Bottom" Height="200">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Bottom" Margin="5,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                   
                                    <Border Grid.Column="0" Background="#EC9C9D" CornerRadius="4,4,0,0" Height="{Binding IncomeHeight}" VerticalAlignment="Bottom" Margin="2,0"/>
                                    
                                    
                                    <Border Grid.Column="1" Background="#7F5836" CornerRadius="4,4,0,0" Height="{Binding ExpenseHeight}" VerticalAlignment="Bottom" Margin="2,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    
                    <ItemsControl x:Name="icDays" Grid.Row="2" Margin="0,5,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DayName}" HorizontalAlignment="Center" FontSize="12" Foreground="#AA7F66"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            
            <Border Grid.Row="2" Background="White" CornerRadius="15,15,0,0" Margin="0" BorderBrush="#AA7F66" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Acasă" Background="Transparent" BorderThickness="0" Foreground="#AA7F66" FontWeight="SemiBold" Click="btnNavHome_Click"/>
                    <Button Grid.Column="1" Content="Activitate" Background="Transparent" BorderThickness="0" Foreground="#443025" FontWeight="Bold" Click="btnNavActivity_Click"/>
                    <Button Grid.Column="2" Content="Profil" Background="Transparent" BorderThickness="0" Foreground="#AA7F66" FontWeight="SemiBold"/>
                </Grid>
            </Border>
        </Grid>

        
        <Border x:Name="AddView" Background="#F5E1E6" Visibility="Collapsed">
            <ScrollViewer>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Adăugare Tranzacție" FontSize="20" FontWeight="Bold" Foreground="#443025" Margin="0,10,0,20" HorizontalAlignment="Center" Grid.Row="0"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="Tip tranzacție" FontWeight="SemiBold" Foreground="#443025" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbCheltuiala" Content="Cheltuială" IsChecked="True" Foreground="#443025" Margin="0,0,30,0"/>
                            <RadioButton x:Name="rbVenit" Content="Venit" Foreground="#443025"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,15">
                        <TextBlock Text="Sumă (RON)" FontWeight="SemiBold" Foreground="#443025" Margin="0,0,0,5"/>
                        <Border Background="White" CornerRadius="8" BorderBrush="#AA7F66" BorderThickness="1">
                            <TextBox x:Name="txtSuma" Padding="10" Background="Transparent" Foreground="#443025" BorderThickness="0"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,15">
                        <TextBlock Text="Descriere" FontWeight="SemiBold" Foreground="#443025" Margin="0,0,0,5"/>
                        <Border Background="White" CornerRadius="8" BorderBrush="#AA7F66" BorderThickness="1">
                            <TextBox x:Name="txtDescriere" Padding="10" Background="Transparent" Foreground="#443025" BorderThickness="0"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,0,0,15">
                        <TextBlock Text="Categorie" FontWeight="SemiBold" Foreground="#443025" Margin="0,0,0,5"/>
                        <Border Background="White" CornerRadius="8" BorderBrush="#AA7F66" BorderThickness="1">
                            <ComboBox x:Name="cmbCategorie" Padding="5" Background="Transparent" Foreground="#443025" BorderThickness="0">
                                <ComboBoxItem Content="Mâncare" IsSelected="True"/>
                                <ComboBoxItem Content="Transport"/>
                                <ComboBoxItem Content="Facturi"/>
                                <ComboBoxItem Content="Divertisment"/>
                                <ComboBoxItem Content="Salariu"/>
                                <ComboBoxItem Content="Altele"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,0,0,15">
                        <TextBlock Text="Metodă de Plată" FontWeight="SemiBold" Foreground="#443025" Margin="0,0,0,5"/>
                        <Border Background="White" CornerRadius="8" BorderBrush="#AA7F66" BorderThickness="1">
                            <ListBox x:Name="lstMetodaPlata" Height="65" Padding="2" Background="Transparent" Foreground="#443025" BorderThickness="0" SelectionMode="Single">
                                <ListBoxItem Content="Cash" IsSelected="True"/>
                                <ListBoxItem Content="Card Bancar"/>
                                <ListBoxItem Content="Transfer"/>
                            </ListBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Margin="0,0,0,15">
                        <TextBlock Text="Data" FontWeight="SemiBold" Foreground="#443025" Margin="0,0,0,5"/>
                        <Border Background="White" CornerRadius="8" Padding="5" BorderBrush="#AA7F66" BorderThickness="1">
                            <DatePicker x:Name="dpData" Background="Transparent" Foreground="#443025" BorderThickness="0"/>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="7" Margin="0,0,0,20">
                        <TextBlock Text="Opțiuni" FontWeight="SemiBold" Foreground="#443025" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkUrgent" Content="Urgent" Foreground="#443025" Margin="0,0,15,0"/>
                            <CheckBox x:Name="chkPersonal" Content="Personal" Foreground="#443025" Margin="0,0,15,0"/>
                            <CheckBox x:Name="chkRecurent" Content="Recurent" Foreground="#443025" Margin="0,0,15,0"/>
                            <CheckBox x:Name="chkEsential" Content="Esențial" Foreground="#443025" Margin="0,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    
                    <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="btnInapoi" Content="Anulează" Width="120" Height="40" Margin="5"
                                Background="White" Foreground="#7F5836" FontWeight="Bold" BorderThickness="1" BorderBrush="#7F5836" Click="btnInapoi_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnAdauga" Content="Salvează" Width="120" Height="40" Margin="5"
                                Background="#443025" Foreground="#F5E1E6" FontWeight="Bold" BorderThickness="0" Click="btnAdauga_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="txtError" Grid.Row="9" Foreground="#7F5836" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" Margin="5,15,5,0"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>