<Window x:Class="BugetApp.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PursePalette" Height="400" Width="550"
        Background="#F3E5F5">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Informații Tranzacție" FontSize="20" FontWeight="Bold" 
                   Foreground="#6A1B9A" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Background="#F1F8E9" CornerRadius="10" Padding="15" BorderBrush="#E1BEE7" BorderThickness="2">
            <StackPanel>
                <TextBlock x:Name="txtDescriere" 
               Text="Descriere: " 
               FontFamily="Gabriola" 
               FontSize="22" 
               FontWeight="Bold" 
               Foreground="#6A1B9A" 
               Margin="5,0,5,5"/>

                <TextBlock x:Name="txtSuma" 
               Text="Sumă: " 
               FontFamily="Gabriola" 
               FontSize="22" 
               FontWeight="Bold" 
               Foreground="#6A1B9A" 
               Margin="5,0,5,5"/>

                <TextBlock x:Name="txtTip" 
               Text="Tip: " 
               FontFamily="Gabriola" 
               FontSize="22" 
               FontWeight="Bold" 
               Foreground="#6A1B9A" 
               Margin="5,0,5,5"/>

                <TextBlock x:Name="txtData" 
               Text="Data: " 
               FontFamily="Gabriola" 
               FontSize="22" 
               FontWeight="Bold" 
               Foreground="#6A1B9A" 
               Margin="5,0,5,5"/>
            </StackPanel>
        </Border>

        <Button Content="Închide" Margin="0,20,0,0" Width="100" Height="30"
                Background="#BA68C8" BorderThickness="0" Cursor="Hand"/>
    </StackPanel>
</Window>