<Window x:Class="BugetApp.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PursePalette" Height="480" Width="430"
        Background="#F7F3ED">
    
    <Grid>
        <!-- VEDEREA DE START (Home) -->
        <Border x:Name="HomeView" Background="#EFD8D6" CornerRadius="12" Margin="30" Padding="20" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="PursePalette" FontSize="36" FontWeight="Bold" Foreground="#422B23" HorizontalAlignment="Center" Margin="0,0,0,10" FontFamily="Segoe UI Historic"/>
                <TextBlock Text="Gestionează-ți bugetul ușor și rapid!" FontSize="16" Foreground="#422B23" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                
                <Button x:Name="btnDeschideAdaugare" Content="Adaugă Tranzacție" Width="220" Height="50"
                        Background="#DBA1A2" Foreground="#422B23" FontWeight="Bold" FontSize="16" 
                        BorderThickness="0" Cursor="Hand" Click="btnDeschideAdaugare_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- VEDEREA DE ADAUGARE (Formular) -->
        <Border x:Name="AddView" Background="#C2C6B9" Margin="15" CornerRadius="10" Padding="15" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Adăugare Tranzacție Nouă" FontSize="20" FontWeight="Bold" 
                           Foreground="#422B23" HorizontalAlignment="Center" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20"/>

                <Label x:Name="lblSuma" Content="Sumă (RON):" Grid.Row="1" Grid.Column="0" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#422B23"/>
                <TextBox x:Name="txtSuma" Grid.Row="1" Grid.Column="1" Margin="5" Padding="4" Background="#F7F3ED" Foreground="#422B23" BorderThickness="0" VerticalAlignment="Center"/>

                <Label x:Name="lblDescriere" Content="Descriere:" Grid.Row="2" Grid.Column="0" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#422B23"/>
                <TextBox x:Name="txtDescriere" Grid.Row="2" Grid.Column="1" Margin="5" Padding="4" Background="#F7F3ED" Foreground="#422B23" BorderThickness="0" VerticalAlignment="Center"/>

                <Label x:Name="lblTip" Content="Tip tranzacție:" Grid.Row="3" Grid.Column="0" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#422B23"/>
                <ComboBox x:Name="cmbTip" Grid.Row="3" Grid.Column="1" Margin="5" Padding="4" Background="#F7F3ED" Foreground="#422B23" BorderThickness="0" VerticalAlignment="Center"/>

                <Label x:Name="lblData" Content="Data:" Grid.Row="4" Grid.Column="0" Margin="5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#422B23"/>
                <DatePicker x:Name="dpData" Grid.Row="4" Grid.Column="1" Margin="5" Padding="4" Background="#F7F3ED" Foreground="#422B23" BorderThickness="0" VerticalAlignment="Center"/>
                
                <Label x:Name="lblOptiuni" Content="Opțiuni:" Grid.Row="5" Grid.Column="0" Margin="5" FontWeight="SemiBold" Foreground="#422B23"/>
                <StackPanel Grid.Row="5" Grid.Column="1" Margin="5">
                    <CheckBox x:Name="chkUrgent" Content="Urgent" Margin="0,0,0,5" Foreground="#422B23"/>
                    <CheckBox x:Name="chkPersonal" Content="Personal" Margin="0,0,0,5" Foreground="#422B23"/>
                    <CheckBox x:Name="chkRecurent" Content="Recurent" Margin="0,0,0,5" Foreground="#422B23"/>
                    <CheckBox x:Name="chkEsential" Content="Esențial" Foreground="#422B23"/>
                </StackPanel>

                <!-- Zone pentru Butoane -->
                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button x:Name="btnInapoi" Content="Înapoi" Width="100" Height="38" Margin="5"
                            Background="#EFD8D6" Foreground="#422B23" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnInapoi_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnAdauga" Content="Salvează" Width="140" Height="38" Margin="5"
                            Background="#DBA1A2" Foreground="#422B23" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnAdauga_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="txtError" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Foreground="Red" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" Margin="5,10,5,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>